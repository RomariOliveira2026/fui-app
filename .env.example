# Fui! — variáveis para deploy beta (Vercel / homologação)
# Copie para .env local ou configure no painel Vercel → Settings → Environment Variables
#
# OAuth callback (cadastrar no portal OAuth após obter a URL da Vercel):
#   https://SEU-PROJETO.vercel.app/api/oauth/callback

# ── Beta demo (app operacional na Vercel sem OAuth) ─────────────────────────
# Servidor (runtime): BETA_DEMO=true  → /api/app-config + auth.me fallback
# Frontend (embutido no build): VITE_BETA_DEMO=true
# BETA_DEMO=true
# VITE_BETA_DEMO=true

# ── Demo operacional (frota fake + aceite automático de corrida) ─────────────
# Liga automaticamente com BETA_DEMO=true. Para desligar mesmo no beta:
# DEMO_OPERATIONAL_RIDES=false
# VITE_DEMO_OPERATIONAL_RIDES=false
# Ativar explicitamente (local sem BETA_DEMO):
# DEMO_OPERATIONAL_RIDES=true
# VITE_DEMO_OPERATIONAL_RIDES=true

# ── Obrigatórias (auth + sessão) ─────────────────────────────────────────────
JWT_SECRET=                    # Segredo para cookies de sessão (string longa aleatória, 32+ chars)
VITE_APP_ID=                   # ID do app no portal OAuth Manus/Forge
OAUTH_SERVER_URL=              # URL base do servidor OAuth (ex.: https://...)
VITE_OAUTH_PORTAL_URL=         # URL do portal de login (frontend)

# ── Banco (opcional em beta demo — sem DATABASE_URL o app usa stores demo in-memory) ───
DATABASE_URL=                  # mysql://user:pass@host:3306/fui

# ── Admin / owner ────────────────────────────────────────────────────────────
OWNER_OPEN_ID=                 # openId do administrador principal (acesso /admin em produção)

# ── Runtime (Vercel define NODE_ENV=production automaticamente) ──────────────
# NODE_ENV=production

# ── Frontend (build Vite — prefixo VITE_ embutido no bundle no deploy) ───────
VITE_APP_TITLE=Fui!
# VITE_APP_CITY=                  # Cidade operacional — ver ordem de expansão abaixo
# Ordem de expansão Sergipe (VITE_APP_CITY = displayName):
#   1. Aracaju
#   2. Nossa Senhora do Socorro
#   3. Lagarto
#   4. Nossa Senhora da Glória
#   5. Estância
#   6. Propriá
#   7. Tobias Barreto
#   8. Maceió
#   9. Petrolina
# Piloto: Itabaiana (padrão quando vazio). Vazio = app nacional (Brasil inteiro).
VITE_PRIMARY_COLOR=#F39200
VITE_PLATFORM_FEE_PERCENT=15

# Mapas (opcional — sem chave usa OpenStreetMap em todo o Brasil)
# VITE_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=
# VITE_REQUEST_RIDE_MAP_PROVIDER=leaflet

# Stripe (opcional — pagamentos cartão)
# VITE_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Firebase push (opcional)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Forge / Manus API (opcional — proxy Maps, imagens)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=

# Analytics Umami (opcional)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# Suporte / Landing comercial
# VITE_SUPPORT_WHATSAPP=79999348812
# VITE_LANDING_WHATSAPP=79999348812
# VITE_LANDING_CONTACT_NAME=Romário
# VITE_LANDING_EMAIL=contato@suaempresa.com.br

# ── Domínio próprio (go-live fuiapp.com.br) ─────────────────────────────────
# URL canônica embutida no build — usada em redirects, links compartilhados e checklist admin
# VITE_APP_URL=https://fuiapp.com.br
# Manter false em produção para redirecionar previews *.vercel.app → VITE_APP_URL
# VITE_ALLOW_PREVIEW_HOST=false
